APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/room_booking
AUTH_SECRET_KEY=replace-with-a-long-random-secret
# Optional one-time admin bootstrap secret. Leave empty unless creating/promoting
# the first admin on a host where shell access is unavailable.
ADMIN_BOOTSTRAP_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
BOOKING_HOLD_MINUTES=30
AUTH_RATE_LIMIT_PER_MINUTE=120
TRUST_PROXY_HEADERS=0
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=5242880
PUBLIC_API_BASE_URL=http://localhost:8000
STORAGE_PROVIDER=local
# S3-compatible storage settings, required when STORAGE_PROVIDER=s3.
# Works with AWS S3, Cloudflare R2, DigitalOcean Spaces, and similar providers.
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_BASE_URL=http://localhost:3000
EMAIL_FROM=noreply@hybridrooms.local
EMAIL_PROVIDER=log
ALLOW_LOG_EMAIL_IN_PRODUCTION=0
# Brevo HTTPS email provider settings, required when EMAIL_PROVIDER=brevo.
BREVO_API_KEY=
# SMTP settings, required when EMAIL_PROVIDER=smtp.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1
SMTP_USE_SSL=0
PAYMENT_PROVIDER=mock
ALLOW_MOCK_PAYMENTS_IN_PRODUCTION=0
# Razorpay production settings, required when PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Stripe production settings, required when PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SQL_ECHO=0
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
